<%- include('partials/header') %>

<h1>Edit Product</h1>

<% if (error) { %>
    <div class="alert error"><%= error %></div>
<% } %>

<form method="POST" action="/api/products/<%= product.id %>/edit" class="product-form">
    <div class="form-group">
        <label>Product Name *</label>
        <input type="text" name="name" value="<%= product.name %>" required>
    </div>
    <div class="form-group">
        <label>Description</label>
        <textarea name="description" rows="5"><%= product.description || '' %></textarea>
    </div>
    <div class="form-row">
        <div class="form-group">
            <label>Price ($) *</label>
            <input type="number" step="0.01" name="price" value="<%= product.price %>" required>
        </div>
        <div class="form-group">
            <label>Stock Quantity</label>
            <input type="number" name="stock_quantity" value="<%= product.stock_quantity %>">
        </div>
    </div>
    <div class="form-group">
        <label>Category</label>
        <select name="category">
            <option value="Electronics" <%= product.category === 'Electronics' ? 'selected' : '' %>>Electronics</option>
            <option value="Fashion" <%= product.category === 'Fashion' ? 'selected' : '' %>>Fashion</option>
            <option value="Home & Living" <%= product.category === 'Home & Living' ? 'selected' : '' %>>Home & Living</option>
            <option value="Books" <%= product.category === 'Books' ? 'selected' : '' %>>Books</option>
            <option value="Handmade" <%= product.category === 'Handmade' ? 'selected' : '' %>>Handmade</option>
            <option value="Vintage" <%= product.category === 'Vintage' ? 'selected' : '' %>>Vintage</option>
            <option value="Sports" <%= product.category === 'Sports' ? 'selected' : '' %>>Sports</option>
            <option value="Beauty" <%= product.category === 'Beauty' ? 'selected' : '' %>>Beauty</option>
            <option value="Toys" <%= product.category === 'Toys' ? 'selected' : '' %>>Toys</option>
            <option value="Pet Supplies" <%= product.category === 'Pet Supplies' ? 'selected' : '' %>>Pet Supplies</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a href="/dashboard" class="btn">Cancel</a>
</form>

<form method="POST" action="/api/products/<%= product.id %>/delete" class="delete-form" onsubmit="return confirm('Are you sure you want to delete this product?')">
    <button type="submit" class="btn btn-danger">Delete Product</button>
</form>

<%- include('partials/footer') %>