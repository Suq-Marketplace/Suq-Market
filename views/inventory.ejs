<%- include('partials/header') %>

<h1>Inventory Management</h1>

<a href="/products/add" class="btn btn-primary">+ Add New Product</a>

<% if (products && products.length > 0) { %>
    <table class="data-table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% products.forEach(product => { %>
                <tr>
                    <td><%= product.name %></td>
                    <td>$<%= product.price %></td>
                    <td class="<%= product.stock_quantity <= 5 ? 'low-stock' : '' %>">
                        <%= product.stock_quantity %>
                    </td>
                    <td>
                        <% if (product.stock_quantity === 0) { %>
                            <span class="badge danger">Out of Stock</span>
                        <% } else if (product.stock_quantity <= 5) { %>
                            <span class="badge warning">Low Stock</span>
                        <% } else { %>
                            <span class="badge success">In Stock</span>
                        <% } %>
                    </td>
                    <td>
                        <a href="/products/edit/<%= product.id %>" class="btn-small">Edit</a>
                        <form method="POST" action="/api/products/<%= product.id %>/stock" class="inline-form">
                            <input type="number" name="quantity" placeholder="+/-" style="width: 60px;">
                            <button type="submit" class="btn-small">Update</button>
                        </form>
                    </td>
                </tr>
            <% }); %>
        </tbody>
    </table>
<% } else { %>
    <p>You haven't added any products yet. <a href="/products/add">Add your first product</a></p>
<% } %>

<%- include('partials/footer') %>