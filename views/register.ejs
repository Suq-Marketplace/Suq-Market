<%- include('partials/header') %>

<h1>Register</h1>

<% if (error) { %>
    <div class="alert error"><%= error %></div>
<% } %>

<form method="POST" action="/api/users/register" class="auth-form">
    <div class="form-group">
        <label>Username *</label>
        <input type="text" name="username" placeholder="Choose a username" required>
    </div>
    <div class="form-group">
        <label>Email *</label>
        <input type="email" name="email" placeholder="Your email address" required>
    </div>
    <div class="form-group">
        <label>Full Name</label>
        <input type="text" name="full_name" placeholder="Your full name">
    </div>
    <div class="form-group">
        <label>Bio</label>
        <textarea name="bio" rows="3" placeholder="Tell us about yourself..."></textarea>
    </div>
    <div class="form-group">
        <label>Password *</label>
        <input type="password" name="password" placeholder="Minimum 6 characters" required>
    </div>
    <div class="form-group">
        <label>Confirm Password *</label>
        <input type="password" name="confirm_password" placeholder="Re-enter your password" required>
    </div>
    <button type="submit" class="btn btn-primary">Register</button>
</form>

<p class="text-center">Already have an account? <a href="/login">Login here</a></p>

<%- include('partials/footer') %>