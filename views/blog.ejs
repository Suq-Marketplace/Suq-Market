<%- include('partials/header') %>

<h1>Blog</h1>
<p class="tagline">Thoughts on marketplace, selling, and community.</p>

<% if (posts && posts.length > 0) { %>
    <div class="posts-list">
        <% posts.forEach(post => { %>
            <div class="post-card">
                <h2><%= post.title %></h2>
                <div class="post-meta">
                    By <strong><%= post.author_name %></strong> on 
                    <%= new Date(post.created_at).toLocaleDateString() %>
                </div>
                <p><%= post.excerpt %></p>
                <a href="/blog/<%= post.slug %>" class="btn-small">Continue reading →</a>
            </div>
        <% }); %>
    </div>
<% } else { %>
    <p>No blog posts yet. Check back soon!</p>
<% } %>

<%- include('partials/footer') %>